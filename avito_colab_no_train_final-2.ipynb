        "## 8. Метрики и retrieval-функции"
      ],
      "id": "n59qi0OmuKOd"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "Nrg_YiL4uKOd"
      },
      "outputs": [],
      "source": [
        "def parse_gt(value):\n",
        "    return {int(v) for v in str(value).split() if v}\n",
        "\n",
        "def ap_at_k(ranked, relevant, k=10):\n",
        "    if not relevant:\n",
        "        return 0.0\n",
        "    seen, hits, score = set(), 0, 0.0\n",
        "    for rank, aid in enumerate(ranked[:k], 1):\n",
        "        aid = int(aid)\n",
        "        if aid in seen:\n",
        "            continue\n",
        "        seen.add(aid)\n",
        "        if aid in relevant:\n",
        "            hits += 1\n",
        "            score += hits / rank\n",
        "    return score / min(len(relevant), k)\n",
        "\n",
        "def map_at_k(rankings, ground_truths, k=10):\n",
        "    return float(np.mean([ap_at_k(r, gt, k) for r, gt in zip(rankings, ground_truths)]))\n",
        "\n",
        "def recall_at_k(rankings, ground_truths, k):\n",
        "    return float(np.mean([len(set(r[:k]) & gt)/len(gt) if gt else 0 for r,gt in zip(rankings,ground_truths)]))\n",
        "\n",
        "def aggregate_chunk_max(chunk_scores):\n",
        "    result = np.full(len(articles), -np.inf, dtype=np.float32)\n",
        "    np.maximum.at(result, CHUNK_ARTICLE_INDEX, np.asarray(chunk_scores, dtype=np.float32))\n",
        "    return result\n",
        "\n",
        "def top_article_ids(scores, topn):\n",
        "    topn = min(topn, len(scores))\n",
        "    idx = np.argpartition(-scores, topn-1)[:topn]\n",
        "    idx = idx[np.argsort(-scores[idx], kind='stable')]\n",
        "    return ARTICLE_IDS[idx].astype(int).tolist()\n",
        "\n",
        "def rrf_fuse(named_rankings, weights, topn, k=None):\n",
        "    k = CFG['rrf_k'] if k is None else k\n",
        "    scores, best_rank = defaultdict(float), {}\n",
        "    for name, ranking in named_rankings:\n",
        "        weight = weights.get(name, 1.0)\n",
        "        for rank, aid in enumerate(ranking, 1):\n",
        "            aid = int(aid)\n",
        "            scores[aid] += weight / (k + rank)\n",
        "            best_rank[aid] = min(best_rank.get(aid, rank), rank)\n",
        "    return sorted(scores, key=lambda aid: (-scores[aid], best_rank[aid], aid))[:topn]"
      ],
      "id": "Nrg_YiL4uKOd"
    },
