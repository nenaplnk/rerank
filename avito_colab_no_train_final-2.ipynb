        "def retrieve_batch(queries):\n",
        "    query_embeddings = dense_model.encode(\n",
        "        ['query: ' + q for q in queries],\n",
        "        batch_size=CFG['dense_batch_size'], normalize_embeddings=True,\n",
        "        convert_to_numpy=True, show_progress_bar=True,\n",
        "    ).astype('float32')\n",
        "    dense_chunk_matrix = query_embeddings @ CHUNK_EMBEDDINGS.T\n",
        "    char_queries = char_vectorizer.transform(queries)\n",
        "    char_scores_matrix = (char_queries @ CHAR_MATRIX.T).toarray().astype('float32')\n",
        "\n",
        "    results = []\n",
        "    for i, query in enumerate(tqdm(queries, desc='retrieve')):\n",
        "        tokens = lexical_tokens(query) or ['_empty_']\n",
        "        title_scores = bm25_title.get_scores(tokens).astype('float32')\n",
        "        body_scores = bm25_body.get_scores(tokens).astype('float32')\n",
        "        bm25_chunk_scores = bm25_chunks.get_scores(tokens).astype('float32')\n",
        "        bm25_chunk_article = aggregate_chunk_max(bm25_chunk_scores)\n",
        "        dense_chunk_scores = dense_chunk_matrix[i]\n",
        "        dense_article = aggregate_chunk_max(dense_chunk_scores)\n",
        "        method_lists = {\n",
        "            'bm25_title': top_article_ids(title_scores, CFG['candidate_pool']),\n",
        "            'bm25_body': top_article_ids(body_scores, CFG['candidate_pool']),\n",
        "            'bm25_chunk': top_article_ids(bm25_chunk_article, CFG['candidate_pool']),\n",
        "            'char_tfidf': top_article_ids(char_scores_matrix[i], CFG['candidate_pool']),\n",
        "            'dense': top_article_ids(dense_article, CFG['candidate_pool']),\n",
        "        }\n",
        "        initial = rrf_fuse(\n",
        "            method_lists.items(), CFG['source_weights'], CFG['candidate_pool']\n",
        "        )\n",
        "        results.append({\n",
        "            'method_lists': method_lists, 'initial': initial,\n",
        "            'dense_chunk_scores': dense_chunk_scores,\n",
        "            'bm25_chunk_scores': bm25_chunk_scores,\n",
        "        })\n",
        "    return results\n",
        "\n",
        "cal_queries = calibration.query_text.astype(str).tolist()\n",
        "test_queries = test.query_text.astype(str).tolist()\n",
        "cal_retrieval = retrieve_batch(cal_queries)\n",
        "test_retrieval = retrieve_batch(test_queries)"
      ],
