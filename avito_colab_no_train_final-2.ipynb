        "import pymorphy3\n",
        "\n",
        "TOKEN_RE = re.compile(r'[а-яёa-z0-9]+', re.I)\n",
        "STOP_WORDS = set('а алло будьте бы вам вас вот вы где да добрый день его ее если есть ещё здравствуйте здравствуй и из или как к ко ли меня мне можете можно мой моя мы на нам нас но о об он она они от по пожалуйста подскажите при про с скажите со спасибо так также то у что это я'.split())\n",
        "morph = pymorphy3.MorphAnalyzer()\n",
        "lemma_cache = {}\n",
        "\n",
        "def lemma(token):\n",
        "    if token not in lemma_cache:\n",
        "        lemma_cache[token] = morph.parse(token)[0].normal_form\n",
        "    return lemma_cache[token]\n",
        "\n",
        "def lexical_tokens(text):\n",
        "    tokens = TOKEN_RE.findall(str(text).lower().replace('ё','е'))\n",
        "    return [lemma(t) for t in tokens if len(t) > 1 and t not in STOP_WORDS]\n",
        "\n",
        "title_tokens = [lexical_tokens(x) or ['_empty_'] for x in tqdm(articles.title, desc='BM25 title')]\n",
        "body_tokens = [lexical_tokens(x) or ['_empty_'] for x in tqdm(articles.body_clean, desc='BM25 body')]\n",
        "chunk_tokens = [lexical_tokens(x) or ['_empty_'] for x in tqdm(chunks.text, desc='BM25 chunks')]\n",
        "bm25_title = BM25Okapi(title_tokens)\n",
        "bm25_body = BM25Okapi(body_tokens)\n",
        "bm25_chunks = BM25Okapi(chunk_tokens)\n",
        "\n",
        "char_vectorizer = TfidfVectorizer(\n",
        "    analyzer='char_wb', ngram_range=(3,5), min_df=2, max_features=200_000,\n",
        "    sublinear_tf=True, norm='l2', dtype=np.float32, lowercase=True,\n",
        ")\n",
        "article_texts = (articles.title + '. ' + articles.body_clean).tolist()\n",
        "CHAR_MATRIX = char_vectorizer.fit_transform(article_texts)\n",
        "print('char matrix:', CHAR_MATRIX.shape)"
      ],
      "id": "GeXNN3JFuKOd"
    },
