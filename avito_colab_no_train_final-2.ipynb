        "def encoded_length(tokenizer, text):\n",
        "    return len(tokenizer.encode(text, add_special_tokens=True, truncation=False))\n",
        "\n",
        "def make_dense_chunks(title, body_text):\n",
        "    title = SPACE_RE.sub(' ', str(title)).strip()\n",
        "    body_ids = dense_tokenizer.encode(\n",
        "        body_text, add_special_tokens=False, truncation=False, verbose=False\n",
        "    )\n",
        "    prefix_ids = dense_tokenizer.encode(\n",
        "        f'passage: {title}. ', add_special_tokens=False, truncation=False\n",
        "    )\n",
        "    special = dense_tokenizer.num_special_tokens_to_add(pair=False)\n",
        "    hard_budget = CFG['dense_max_length'] - len(prefix_ids) - special - 8\n",
        "    body_budget = min(CFG['dense_body_tokens'], hard_budget)\n",
        "    assert body_budget > CFG['dense_overlap_tokens']\n",
        "    if not body_ids:\n",
        "        text = title\n",
        "        return [(text, encoded_length(dense_tokenizer, f'passage: {text}'))]\n",
        "\n",
        "    chunks = []\n",
        "    start, end = 0, 0\n",
        "    while start < len(body_ids):\n",
        "        end = min(start + body_budget, len(body_ids))\n",
        "        piece = dense_tokenizer.decode(body_ids[start:end], skip_special_tokens=True).strip()\n",
        "        chunk = f'{title}. {piece}'.strip()\n",
        "        length = encoded_length(dense_tokenizer, f'passage: {chunk}')\n",
        "        while length > CFG['dense_max_length'] and end > start + 1:\n",
        "            overflow = length - CFG['dense_max_length']\n",
        "            end = max(start + 1, end - overflow - 4)\n",
        "            piece = dense_tokenizer.decode(body_ids[start:end], skip_special_tokens=True).strip()\n",
        "            chunk = f'{title}. {piece}'.strip()\n",
        "            length = encoded_length(dense_tokenizer, f'passage: {chunk}')\n",
        "        chunks.append((chunk, length))\n",
        "        if end >= len(body_ids):\n",
        "            break\n",
        "        start = max(start + 1, end - CFG['dense_overlap_tokens'])\n",
        "    assert end == len(body_ids), 'Чанкинг не дошёл до конца статьи'\n",
        "    return chunks\n",
        "\n",
        "chunk_rows = []\n",
        "for article_index, row in enumerate(tqdm(articles.itertuples(), total=len(articles), desc='chunk')):\n",
        "    for text, token_length in make_dense_chunks(row.title, row.body_clean):\n",
        "        chunk_rows.append({\n",
        "            'article_index': article_index, 'article_id': int(row.article_id),\n",
        "            'text': text, 'dense_tokens': token_length,\n",
        "        })\n",
        "chunks = pd.DataFrame(chunk_rows).reset_index(names='chunk_id')\n",
        "CHUNK_ARTICLE_INDEX = chunks.article_index.to_numpy(dtype=np.int32)\n",
        "ARTICLE_TO_CHUNKS = [\n",
        "    np.flatnonzero(CHUNK_ARTICLE_INDEX == i).astype(np.int32)\n",
        "    for i in range(len(articles))\n",
        "]\n",
        "assert chunks.dense_tokens.max() <= CFG['dense_max_length']\n",
        "print('chunks:', len(chunks), '| avg/article:', round(len(chunks)/len(articles), 2),\n",
        "      '| max tokens:', int(chunks.dense_tokens.max()),\n",
        "      '| max chunks/article:', max(map(len, ARTICLE_TO_CHUNKS)))"
      ],
      "id": "NohYBTuwuKOd"
    },
