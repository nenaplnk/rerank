      "source": [
        "## 9. BGE cross-encoder\n",
        "\n",
        "После этой точки dense-модель выгружается из GPU. BGE получает все чанки каждой из 100 статей-кандидатов. Если пара длиннее лимита, она разбивается, а не обрезается."
      ],
      "id": "ZGi047aCuKOe"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "DUp-t-yluKOe",
        "outputId": "32afa2b5-155e-4e3c-eded-2fe24104a221"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "reranker loaded\n"
          ]
        }
      ],
      "source": [
        "for name in ('dense_model', 'reranker_model'):\n",
        "    if name in globals():\n",
        "        del globals()[name]\n",
        "gc.collect()\n",
        "torch.cuda.empty_cache()\n",
        "\n",
        "from transformers import AutoModelForSequenceClassification, AutoTokenizer\n",
        "\n",
        "reranker_tokenizer = AutoTokenizer.from_pretrained(\n",
        "    CFG['reranker_model'], cache_dir=str(MODEL_CACHE_DIR)\n",
        ")\n",
        "reranker_model = AutoModelForSequenceClassification.from_pretrained(\n",
        "    CFG['reranker_model'], cache_dir=str(MODEL_CACHE_DIR),\n",
        "    torch_dtype=torch.float16,\n",
        ").to(DEVICE).eval()\n",
        "print('reranker loaded')"
      ],
      "id": "DUp-t-yluKOe"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "qtrQR1KvuKOe"
      },
      "outputs": [],
      "source": [
        "def select_chunks(article_index, result):\n",
        "    candidates = ARTICLE_TO_CHUNKS[article_index]\n",
        "    if CFG['rerank_chunks_per_article'] is None:\n",
        "        return [int(idx) for idx in candidates]\n",
        "    dense_order = candidates[np.argsort(-result['dense_chunk_scores'][candidates], kind='stable')]\n",
        "    bm25_order = candidates[np.argsort(-result['bm25_chunk_scores'][candidates], kind='stable')]\n",
        "    selected = []\n",
        "    for rank in range(max(len(dense_order), len(bm25_order))):\n",
        "        for order in (dense_order, bm25_order):\n",
        "            if rank < len(order):\n",
        "                idx = int(order[rank])\n",
        "                if idx not in selected:\n",
        "                    selected.append(idx)\n",
        "                    if len(selected) == CFG['rerank_chunks_per_article']:\n",
        "                        return selected\n",
        "    return selected\n",
        "\n",
        "def split_pair_to_fit(query, passage):\n",
        "    pair_ids = reranker_tokenizer.encode(\n",
        "        query, passage, add_special_tokens=True, truncation=False, verbose=False\n",
        "    )\n",
        "    if len(pair_ids) <= CFG['reranker_max_length']:\n",
        "        return [passage]\n",
        "    query_ids = reranker_tokenizer.encode(\n",
        "        query, add_special_tokens=False, truncation=False, verbose=False\n",
        "    )\n",
        "    passage_ids = reranker_tokenizer.encode(\n",
        "        passage, add_special_tokens=False, truncation=False, verbose=False\n",
        "    )\n",
        "    special = reranker_tokenizer.num_special_tokens_to_add(pair=True)\n",
        "    budget = CFG['reranker_max_length'] - len(query_ids) - special - 8\n",
        "    assert budget > CFG['reranker_overlap_tokens']\n",
        "    pieces, start = [], 0\n",
        "    while start < len(passage_ids):\n",
        "        end = min(start + budget, len(passage_ids))\n",
        "        piece = reranker_tokenizer.decode(passage_ids[start:end], skip_special_tokens=True).strip()\n",
        "        while len(reranker_tokenizer.encode(\n",
        "            query, piece, add_special_tokens=True, truncation=False, verbose=False\n",
        "        )) > CFG['reranker_max_length']:\n",
        "            end -= 4\n",
        "            piece = reranker_tokenizer.decode(passage_ids[start:end], skip_special_tokens=True).strip()\n",
        "        pieces.append(piece)\n",
        "        if end >= len(passage_ids):\n",
        "            break\n",
        "        start = max(start + 1, end - CFG['reranker_overlap_tokens'])\n",
        "    return pieces\n",
        "\n",
        "@torch.inference_mode()\n",
        "def score_pairs(pairs):\n",
        "    lengths = [len(reranker_tokenizer.encode(\n",
        "        q, p, add_special_tokens=True, truncation=False, verbose=False\n",
        "    )) for q,p in pairs]\n",
        "    assert max(lengths, default=0) <= CFG['reranker_max_length']\n",
        "    order = np.argsort(lengths, kind='stable')\n",
        "    scores = np.empty(len(pairs), dtype=np.float32)\n",
        "    batch_size = CFG['reranker_batch_size']\n",
        "    position = 0\n",
        "    while position < len(order):\n",
        "        idx = order[position:position + batch_size]\n",
        "        batch = [pairs[int(i)] for i in idx]\n",
        "        try:\n",
        "            features = reranker_tokenizer(\n",
        "                [q for q,_ in batch], [p for _,p in batch],\n",
        "                padding=True, truncation=False, return_tensors='pt'\n",
        "            ).to(DEVICE)\n",
        "            with torch.autocast('cuda', dtype=torch.float16):\n",
        "                logits = reranker_model(**features).logits\n",
        "            scores[idx] = logits.float().view(-1).cpu().numpy()\n",
        "            position += len(idx)\n",
        "        except torch.cuda.OutOfMemoryError:\n",
        "            del batch\n",
        "            gc.collect()\n",
        "            torch.cuda.empty_cache()\n",
        "            if batch_size == 1:\n",
        "                raise\n",
        "            batch_size = max(1, batch_size // 2)\n",
        "            print(f'BGE OOM: уменьшаю batch_size до {batch_size}')\n",
        "    return scores"
      ],
      "id": "qtrQR1KvuKOe"
    },
