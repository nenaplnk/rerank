    {
      "cell_type": "markdown",
      "metadata": {
        "id": "sGiUUArQuKOc"
      },
      "source": [
        "## 4. Очистка HTML без потери вкладок, спойлеров и таблиц"
      ],
      "id": "sGiUUArQuKOc"
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "JER4ceyauKOd",
        "outputId": "0362d5c8-3d42-481a-fda0-71d4a1b530d5"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            " article_id                            title                                                                                           body_clean\n",
            "       1730        Имя или название компании Зайдите в раздел Управление профилем\\nНажмите на карандашик в правом верхнем углу\\nВведите новое ...\n",
            "       1746 Понять, что профиль заблокирован Проверьте, какое сообщение вы видите при входе в профиль\\nПрофиль заблокирован\\nДоступ к профилю ...\n"
          ]
        }
      ],
      "source": [
        "SPACE_RE = re.compile(r'[ \\t\\f\\v]+')\n",
        "MULTI_NEWLINE_RE = re.compile(r'\\n{2,}')\n",
        "EMOJI_RE = re.compile(\n",
        "    '[\\U0001F300-\\U0001FAFF\\U00002600-\\U000027BF\\U00002B00-\\U00002BFF'\n",
        "    '\\U0001F1E6-\\U0001F1FF\\uFE0F\\u200D\\u20E3]', re.UNICODE\n",
        ")\n",
        "BLOCK_TAGS = {\n",
        "    'address','article','aside','blockquote','dd','div','dl','dt','figcaption',\n",
        "    'figure','footer','h1','h2','h3','h4','h5','h6','header','hr','li','main',\n",
        "    'ol','p','section','table','tbody','td','tfoot','th','thead','tr','ul',\n",
        "}\n",
        "\n",
        "def html_to_blocks(raw):\n",
        "    if not isinstance(raw, str) or not raw.strip():\n",
        "        return []\n",
        "    soup = BeautifulSoup(html.unescape(raw), 'lxml')\n",
        "    for tag in soup.find_all(['script','style','nav','footer','svg','iframe']):\n",
        "        tag.decompose()\n",
        "    for tag in soup.find_all('br'):\n",
        "        tag.replace_with(NavigableString('\\n'))\n",
        "    for tag in soup.find_all(BLOCK_TAGS):\n",
        "        tag.append(NavigableString('\\n'))\n",
        "    text = soup.get_text(' ', strip=False)\n",
        "    text = EMOJI_RE.sub(' ', text).replace('\\xa0', ' ')\n",
        "    text = SPACE_RE.sub(' ', text)\n",
        "    text = MULTI_NEWLINE_RE.sub('\\n', text)\n",
        "    blocks = []\n",
        "    for line in text.splitlines():\n",
        "        line = SPACE_RE.sub(' ', line).strip(' .\\t')\n",
        "        if line and (not blocks or blocks[-1] != line):\n",
        "            blocks.append(line)\n",
        "    return blocks\n",
        "\n",
        "articles = articles_raw.copy()\n",
        "articles['article_id'] = articles['article_id'].astype('int64')\n",
        "articles['title'] = articles['title'].fillna('').astype(str)\n",
        "articles['body_blocks'] = articles['body'].map(html_to_blocks)\n",
        "articles['body_clean'] = articles['body_blocks'].map(lambda x: '\\n'.join(x))\n",
        "articles = articles.reset_index(drop=True)\n",
        "ARTICLE_IDS = articles.article_id.to_numpy(dtype=np.int64)\n",
        "ID_TO_INDEX = {int(aid): i for i, aid in enumerate(ARTICLE_IDS)}\n",
        "print(articles[['article_id','title','body_clean']].head(2).to_string(index=False, max_colwidth=100))"
      ],
      "id": "JER4ceyauKOd"
    },
