      "source": [
        "test_cross, test_final = rerank_dataset('test', test_queries, test_retrieval)\n",
        "answer = pd.DataFrame({\n",
        "    'query_id': test.query_id.to_numpy(),\n",
        "    'answer': [' '.join(map(str, row[:CFG['topn']])) for row in test_final],\n",
        "})\n",
        "\n",
        "known_ids = set(ARTICLE_IDS.astype(int))\n",
        "assert list(answer.columns) == ['query_id','answer']\n",
        "assert len(answer) == len(test) == 500\n",
        "assert answer.query_id.tolist() == test.query_id.tolist()\n",
        "for row in answer.itertuples(index=False):\n",
        "    ids = [int(v) for v in row.answer.split()]\n",
        "    assert 1 <= len(ids) <= 10\n",
        "    assert len(ids) == len(set(ids))\n",
        "    assert set(ids) <= known_ids\n",
        "\n",
        "answer.to_csv('/content/answer.csv', index=False)\n",
        "print('Сохранено /content/answer.csv:', answer.shape)\n",
        "display(answer.head())"
