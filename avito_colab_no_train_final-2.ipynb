        "dense_model.max_seq_length = CFG['dense_max_length']\n",
        "dense_model.half()\n",
        "dense_tokenizer = dense_model.tokenizer\n",
        "print('dense embedding dim:', dense_model.get_sentence_embedding_dimension())"
