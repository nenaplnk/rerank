      ],
      "source": [
        "required_files = ['articles.f', 'calibration.f', 'test.f']\n",
        "missing = [name for name in required_files if not (DATA_DIR / name).exists()]\n",
        "if missing:\n",
        "    print('Загрузите файлы:', missing)\n",
        "    from google.colab import files\n",
        "    files.upload()\n",
        "\n",
        "articles_raw = pd.read_feather(DATA_DIR / 'articles.f')\n",
        "calibration = pd.read_feather(DATA_DIR / 'calibration.f')\n",
        "test = pd.read_feather(DATA_DIR / 'test.f')\n",
        "\n",
        "assert set(['article_id', 'title', 'body']) <= set(articles_raw.columns)\n",
        "assert set(['query_id', 'query_text', 'ground_truth']) <= set(calibration.columns)\n",
        "assert set(['query_id', 'query_text']) <= set(test.columns)\n",
        "assert articles_raw.article_id.is_unique\n",
        "assert test.query_id.is_unique\n",
        "print('articles:', articles_raw.shape, '| calibration:', calibration.shape, '| test:', test.shape)"
      ],
      "id": "229LrtAIuKOc"
