        "def file_sha256(path):\n",
        "    h = hashlib.sha256()\n",
        "    with open(path, 'rb') as f:\n",
        "        for block in iter(lambda: f.read(1024*1024), b''):\n",
        "            h.update(block)\n",
        "    return h.hexdigest()\n",
        "\n",
        "dense_key_data = {\n",
        "    'articles': file_sha256(DATA_DIR / 'articles.f'),\n",
        "    'model': CFG['dense_model'],\n",
        "    'body_tokens': CFG['dense_body_tokens'],\n",
        "    'overlap': CFG['dense_overlap_tokens'],\n",
        "    'chunk_count': len(chunks),\n",
        "}\n",
        "dense_key = hashlib.sha256(json.dumps(dense_key_data, sort_keys=True).encode()).hexdigest()[:16]\n",
        "dense_cache_path = CACHE_DIR / f'dense_chunks_{dense_key}.npy'\n",
        "\n",
        "if dense_cache_path.exists():\n",
        "    CHUNK_EMBEDDINGS = np.load(dense_cache_path).astype('float32')\n",
        "    assert len(CHUNK_EMBEDDINGS) == len(chunks)\n",
        "    print('[cache]', dense_cache_path)\n",
        "else:\n",
        "    CHUNK_EMBEDDINGS = dense_model.encode(\n",
        "        ['passage: ' + x for x in chunks.text],\n",
        "        batch_size=CFG['dense_batch_size'], normalize_embeddings=True,\n",
        "        convert_to_numpy=True, show_progress_bar=True,\n",
        "    ).astype('float32')\n",
        "    np.save(dense_cache_path, CHUNK_EMBEDDINGS)\n",
        "print('chunk embeddings:', CHUNK_EMBEDDINGS.shape)"
      ],
      "id": "NcdRGjDeuKOd"
    },
