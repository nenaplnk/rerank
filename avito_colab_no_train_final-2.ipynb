        "def rerank_cache_path(label, queries, retrieval):\n",
        "    payload = CFG\n",
        "    key = hashlib.sha256(json.dumps(payload, ensure_ascii=False, sort_keys=True).encode()).hexdigest()[:16]\n",
        "    return CACHE_DIR / f'rerank_{label}_{key}.json', key\n",
        "\n",
        "def rerank_dataset(label, queries, retrieval):\n",
        "    cache_path, cache_key = rerank_cache_path(label, queries, retrieval)\n",
        "    cross_rankings, final_rankings = [], []\n",
        "    if cache_path.exists():\n",
        "        saved = json.loads(cache_path.read_text())\n",
        "        if saved.get('cache_key') == cache_key:\n",
        "            cross_rankings = saved.get('cross', [])\n",
        "            final_rankings = saved.get('final', [])\n",
        "            if len(cross_rankings) != len(final_rankings) or len(cross_rankings) > len(queries):\n",
        "                cross_rankings, final_rankings = [], []\n",
        "            print(f'[cache] {label}: {len(cross_rankings)}/{len(queries)}')\n",
        "\n",
        "    start_index = len(cross_rankings)\n",
        "    final_weights = {\n",
        "        'cross': CFG['final_cross_weight'],\n",
        "        'retrieval': CFG['final_retrieval_weight'],\n",
        "    }\n",
        "    for i in tqdm(range(start_index, len(queries)), desc=f'rerank {label}'):\n",
        "        query, result = queries[i], retrieval[i]\n",
        "        candidate_ids = result['initial'][:CFG['rerank_articles']]\n",
        "        pairs, owners = [], []\n",
        "        for aid in candidate_ids:\n",
        "            article_index = ID_TO_INDEX[int(aid)]\n",
        "            for chunk_index in select_chunks(article_index, result):\n",
        "                for piece in split_pair_to_fit(query, chunks.at[chunk_index, 'text']):\n",
        "                    pairs.append((query, piece))\n",
        "                    owners.append(int(aid))\n",
        "        scores = score_pairs(pairs)\n",
        "        best = {}\n",
        "        for aid, score in zip(owners, scores):\n",
        "            if aid not in best or score > best[aid]:\n",
        "                best[aid] = float(score)\n",
        "        initial_pos = {aid: pos for pos, aid in enumerate(candidate_ids)}\n",
        "        cross = sorted(best, key=lambda aid: (-best[aid], initial_pos[aid], aid))\n",
        "        final = rrf_fuse(\n",
        "            [('cross', cross), ('retrieval', result['initial'])],\n",
        "            final_weights, CFG['topn']\n",
        "        )\n",
        "        cross_rankings.append(cross[:CFG['topn']])\n",
        "        final_rankings.append(final)\n",
        "        if (i + 1) % 5 == 0 or i + 1 == len(queries):\n",
        "            tmp = cache_path.with_suffix('.json.tmp')\n",
        "            tmp.write_text(json.dumps({\n",
        "                'cache_key': cache_key, 'cross': cross_rankings, 'final': final_rankings\n",
        "            }, ensure_ascii=False))\n",
        "            tmp.replace(cache_path)\n",
        "    return cross_rankings, final_rankings"
      ],
      "id": "igfeSkZCuKOe"
    },
